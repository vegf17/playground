   chops1:=-1 (+)(1%2) chops1:=1;
   if(chops1==1)
    then {
     await(cs1==1) do {cs1:=cs1-1};
     if(cs2==1) then {cs2:=cs2-1; try1:=0}
     else {cs1:=cs1+1}
    }
    else{
     await(cs2==1) do {cs2:=cs2-1};
     if(cs1==1) then {cs1:=cs1-1; try1:=0}
     else {cs2:=cs2+1}
    }
  };
  st1:=0;
  while(st1==0) do {st1:=1 or skip};
  eat1:=eat1+1; cs1:=cs1+1; cs2:=cs2+1
 }
