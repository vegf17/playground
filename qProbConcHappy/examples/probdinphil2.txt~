cs:[(st1,1),(st2,1),(cs1,1),(cs2,1),(try1,0),(try2,0),(chops1,0),(chops2,0),(eat1,0),(eat2,0)]

 while(tt) do{
  while(st1==1) do{st1:=2 or skip};
  (try1:=1 or try1:=0);
